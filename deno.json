{
  "unstable": ["kv","cron"],
  "compilerOptions": {
    "lib": [
      "deno.window",
      "deno.unstable",
      "node",
      "dom"
    ],
    "paths": {
      "~/*": ["./source/*"]
    }
  },
  "test": {
    "exclude": [".deno"],
    "permissions": {
      "env": true,
      "read": true,
      "write": true
    }
  },
  "tasks": {
    "dev": "deno check ./source && deno run -A --env main.ts",
		"bin": "deno check ./source && deno compile -A --env --output kaya.exe",
    "test": "deno test --allow-env --allow-read source/",
    "exp": "deno run -A --env ---watch playground.ts",
    "sql": "surreal sql -e http://localhost:8050 --ns default --db default"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "chalk": "npm:chalk@^5.6.2",
    "gramio": "npm:gramio@^0.5.0",
    "surrealdb": "npm:surrealdb@^1.3.2",
    "zod": "npm:zod@^4.3.6"
  }
}
