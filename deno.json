{
  "unstable": ["kv","cron"],
  "compilerOptions": {
    "paths": {
      "~/*": ["./source/*"]
    }
  },
  "test": {
    "exclude": [".deno"],
    "permissions": {
      "env": true,
      "read": true,
      "write": true
    }
  },
  "tasks": {
    "dev": "deno run -A --env  main.ts",
    "test": "deno test --allow-env --allow-read source/",
    "exp": "deno run -A --env ---watch playground.ts",
		"comp": "deno compile -A --env --output kaya.exe"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "gramio": "npm:gramio@^0.5.0",
    "surrealdb": "npm:surrealdb@^1.3.2",
    "zod": "npm:zod@^4.3.6"
  }
}
